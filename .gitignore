# Configuración de entorno — contiene credenciales, NUNCA al repo
includes/.env.php

# Datos generados en runtime (cron jobs los actualizan en el servidor;
# el deploy hace "cp -Rf *" y no borra nada, pero si estuvieran versionados
# el commit viejo pisaría el JSON fresco del servidor en cada deploy)
*.json

# Scripts de análisis/desofuscación de sitios externos (uso local, no versionar)
/reverse-engineering/

# Imágenes descargadas en runtime (admin/fotmob.php, api/partido_extra.php) —
# cada servidor descarga su propio set según los partidos/equipos que importó;
# versionarlas pisaría con un commit viejo las imágenes frescas de producción,
# mismo motivo que la regla "*.json" de arriba.
assets/img/equipos/
assets/img/ligas/
assets/img/jugadores/

# Dependencias del bridge Playwright — se reinstalan con npm install en local
# y se instalan solas en Render vía Dockerfile
tools/sofascore-bridge/node_modules/

# La regla "*.json" de arriba también los atrapaba, pero Render necesita estos
# dos para el build del Dockerfile
!tools/sofascore-bridge/package.json
!tools/sofascore-bridge/package-lock.json
